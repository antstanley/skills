 """Component 4: ``pipeline`` — orchestrate the other three components.
 
 Depends on :mod:`text_toolkit.tokenizer`, :mod:`text_toolkit.normalizer`, and
-:mod:`text_toolkit.frequency`. Skeleton stub.
+:mod:`text_toolkit.frequency`.
 """
 
 from __future__ import annotations
 
+from text_toolkit.tokenizer import tokenize
+from text_toolkit.frequency import word_counts, top_terms
+
 
 def summarize(text: str, limit: int) -> dict[str, object]:
-    """Return a summary dict for ``text``. (TODO: implement.)"""
-    raise NotImplementedError("summarize is not implemented yet")
+    """Return a summary dict for ``text``.
+
+    Returns a dict with three keys:
+
+    - ``'tokens'``: count of raw tokens (``len(tokenize(text))``).
+    - ``'terms'``: count of distinct normalized terms (``len(word_counts(text))``).
+    - ``'top'``: the ``limit`` most frequent ``(term, count)`` pairs
+      (``top_terms(text, limit)``).
+
+    Examples::
+
+        >>> summarize("", 3)
+        {'tokens': 0, 'terms': 0, 'top': []}
+        >>> summarize("the cat and the dog", 2)['tokens']
+        5
+    """
+    tokens = len(tokenize(text))
+    terms = len(word_counts(text))
+    top = top_terms(text, limit)
+    return {'tokens': tokens, 'terms': terms, 'top': top}
