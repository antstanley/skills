 def tokenize(text: str) -> list[str]:
-    """Split ``text`` into a list of word tokens. (TODO: implement.)"""
-    raise NotImplementedError("tokenize is not implemented yet")
+    """Split ``text`` into a list of word tokens.
+
+    Tokens are maximal runs of alphanumeric characters.  The split boundary
+    is any run of one or more non-alphanumeric characters.  Original case and
+    digits are preserved; empty strings are never returned.
+    """
+    import re
+    return [tok for tok in re.split(r"[^a-zA-Z0-9]+", text) if tok]
