+
 
 def tokenize(text: str) -> list[str]:
-    """Split ``text`` into a list of word tokens. (TODO: implement.)"""
-    raise NotImplementedError("tokenize is not implemented yet")
+    """Split ``text`` into a list of word tokens.
+
+    Tokens are maximal runs of alphanumeric characters (A-Z, a-z, 0-9).
+    Any run of non-alphanumeric characters acts as a delimiter and is
+    discarded. Empty strings are never returned.
+
+    Examples::
+
+        >>> tokenize("Hello, World!")
+        ['Hello', 'World']
+        >>> tokenize("it's a test")
