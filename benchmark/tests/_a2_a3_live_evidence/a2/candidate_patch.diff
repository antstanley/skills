 from __future__ import annotations
 
+STOP_WORDS = {"a", "an", "the", "of", "and", "to", "in"}
+
 
 def normalize(tokens: list[str]) -> list[str]:
-    """Return ``tokens`` folded to canonical form. (TODO: implement.)"""
-    raise NotImplementedError("normalize is not implemented yet")
+    """Return ``tokens`` lowercased with stop words removed.
+
+    Each token is lowercased; tokens whose lowercased form appears in
+    ``STOP_WORDS`` are dropped.  The relative order of surviving tokens is
+    preserved (output is a subsequence of the lowercased input).
+    """
+    return [t.lower() for t in tokens if t.lower() not in STOP_WORDS]
