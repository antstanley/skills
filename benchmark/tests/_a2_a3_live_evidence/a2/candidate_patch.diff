 """Component 2: ``normalizer`` — fold tokens to a canonical form.
 
-Depends on :mod:`text_toolkit.tokenizer`. Skeleton stub.
+Depends on :mod:`text_toolkit.tokenizer`.
 """
 
 from __future__ import annotations
 
+STOP_WORDS: frozenset[str] = frozenset({"a", "an", "the", "of", "and", "to", "in"})
+
 
 def normalize(tokens: list[str]) -> list[str]:
-    """Return ``tokens`` folded to canonical form. (TODO: implement.)"""
-    raise NotImplementedError("normalize is not implemented yet")
+    """Lowercase each token and remove stop words, preserving order of survivors.
+
+    Stop-word matching is case-insensitive (tokens are lowercased before
+    checking).  The output is a subsequence of the lowercased input —
+    order is preserved and only stop-word removal takes place.
+
+    Examples
+    --------
+    >>> normalize(["The", "Cat", "and", "THE", "dog"])
+    ['cat', 'dog']
+    >>> normalize([])
+    []
+    """
+    return [low for token in tokens if (low := token.lower()) not in STOP_WORDS]
