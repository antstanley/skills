 """Component 3: ``frequency`` — count and rank normalized terms.
 
 Depends on :mod:`text_toolkit.tokenizer` and :mod:`text_toolkit.normalizer`.
-Skeleton stub.
 """
 
 from __future__ import annotations
 
+import collections
+
+from text_toolkit.tokenizer import tokenize
+from text_toolkit.normalizer import normalize
+
 
 def word_counts(text: str) -> dict[str, int]:
-    """Return a mapping of normalized term -> occurrence count. (TODO.)"""
-    raise NotImplementedError("word_counts is not implemented yet")
+    """Return a mapping of normalized term -> occurrence count.
+
+    Tokenizes ``text`` and normalizes the resulting tokens (lowercasing and
+    stop-word removal), then counts each surviving term.
+
+    Examples::
+
+        >>> word_counts("the the cat")
+        {'cat': 1}
+        >>> word_counts("")
+        {}
+        >>> word_counts("cat dog cat")
+        {'cat': 2, 'dog': 1}
+    """
+    terms = normalize(tokenize(text))
+    return dict(collections.Counter(terms))
 
 
 def top_terms(text: str, limit: int) -> list[tuple[str, int]]:
-    """Return the ``limit`` most frequent ``(term, count)`` pairs. (TODO.)"""
-    raise NotImplementedError("top_terms is not implemented yet")
+    """Return the ``limit`` most frequent ``(term, count)`` pairs.
+
+    Results are sorted by count descending; ties are broken by term ascending
+    (lexicographic order).
+
+    Examples::
+
+        >>> top_terms("cat dog cat", 2)
+        [('cat', 2), ('dog', 1)]
+        >>> top_terms("cat dog cat", 1)
+        [('cat', 2)]
+    """
+    counts = word_counts(text)
+    sorted_terms = sorted(counts.items(), key=lambda item: (-item[1], item[0]))
+    return sorted_terms[:limit]
