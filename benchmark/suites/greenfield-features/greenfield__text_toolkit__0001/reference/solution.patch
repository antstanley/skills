+"""Component 2: ``normalizer`` — fold tokens to a canonical form."""
 
 from __future__ import annotations
 
+_STOP_WORDS = frozenset({"a", "an", "the", "of", "and", "to", "in"})
+
 
 def normalize(tokens: list[str]) -> list[str]:
-    """Return ``tokens`` folded to canonical form. (TODO: implement.)"""
-    raise NotImplementedError("normalize is not implemented yet")
+    """Lowercase each token and drop stop words, preserving order."""
+    folded = (token.lower() for token in tokens)
+    return [token for token in folded if token not in _STOP_WORDS]
